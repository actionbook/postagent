{
  "name": "postagent",
  "version": "0.2.1",
  "description": "CLI collection tool for agents",
  "type": "module",
  "bin": {
    "postagent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "cp ../../README.md .",
    "postinstall": "node scripts/postinstall.cjs",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actionbook/postagent.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "postagent-darwin-arm64": "workspace:*",
    "postagent-darwin-x64": "workspace:*",
    "postagent-linux-x64-gnu": "workspace:*",
    "postagent-linux-arm64-gnu": "workspace:*"
  }
}
